# InheritX Backend Environment Variables

# Database
INHERITX_DATABASE__URL=postgres://username:password@localhost/INHERITX

# Server
INHERITX_PORT=3000

# JWT Configuration
INHERITX_JWT__SECRET=your-super-secret-jwt-key-change-this-in-production
INHERITX_JWT__EXPIRATION_HOURS=24

# Stellar Network Configuration
INHERITX_STELLAR__NETWORK__PASSPHRASE=Test SDF Network ; September 2015
INHERITX_STELLAR__NETWORK__HORIZON_URL=https://horizon-testnet.stellar.org
INHERITX_STELLAR__NETWORK__RPC_URL=https://soroban-testnet.stellar.org

# Anchor Configuration
INHERITX_ANCHOR__SEP24_URL=https://your-anchor.com/sep24
INHERITX_ANCHOR__SEP31_URL=https://your-anchor.com/sep31
INHERITX_ANCHOR__WEBHOOK_SECRET=your-webhook-secret
INHERITX_ANCHOR__KYC_REQUIRED=true

# Bridge Configuration
INHERITX_BRIDGE__ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
INHERITX_BRIDGE__POLYGON_RPC_URL=https://polygon-rpc.com
INHERITX_BRIDGE__BSC_RPC_URL=https://bsc-dataseed.binance.org
INHERITX_BRIDGE__SUPPORTED_ASSETS=["USDC", "USDT"]
INHERITX_BRIDGE__MIN_BRIDGE_AMOUNT=1000000
INHERITX_BRIDGE__MAX_BRIDGE_AMOUNT=100000000

# Compliance Configuration
INHERITX_COMPLIANCE__SANCTIONS_API_URL=https://api.sanctions.example.com
INHERITX_COMPLIANCE__SANCTIONS_API_KEY=your-api-key
INHERITX_COMPLIANCE__VELOCITY_LIMITS__DAILY_TRANSACTION_LIMIT=10000000
INHERITX_COMPLIANCE__VELOCITY_LIMITS__MONTHLY_TRANSACTION_LIMIT=100000000
INHERITX_COMPLIANCE__VELOCITY_LIMITS__MAX_TRANSACTION_AMOUNT=5000000
INHERITX_COMPLIANCE__RISK_THRESHOLDS__HIGH_RISK_AMOUNT=10000000
INHERITX_COMPLIANCE__RISK_THRESHOLDS__MEDIUM_RISK_AMOUNT=1000000

# Environment
RUN_ENV=development

# Logging / Observability
# LOG_FORMAT values: json | pretty
LOG_FORMAT=json

# Optional Sentry integration for error tracking
# SENTRY_DSN=https://<key>@sentry.io/<project-id>
SENTRY_TRACES_SAMPLE_RATE=0.1

# Message Encryption (for legacy messages)
MESSAGE_KEY_ENCRYPTION_KEY=your-message-encryption-master-key-change-this-in-production

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# All values are optional; the defaults shown below are used when not set.

# Global default: sustained requests per second and maximum burst per IP.
RATE_LIMIT_DEFAULT_PER_SECOND=2
RATE_LIMIT_DEFAULT_BURST_SIZE=5

# Emergency-access endpoints (grant/revoke) – intentionally lower.
RATE_LIMIT_EMERGENCY_PER_SECOND=1
RATE_LIMIT_EMERGENCY_BURST_SIZE=2

# Admin login endpoint – low limit for brute-force protection.
RATE_LIMIT_ADMIN_LOGIN_PER_SECOND=1
RATE_LIMIT_ADMIN_LOGIN_BURST_SIZE=3

# Comma-separated list of bearer token values exempt from rate limiting
# (internal services, admin automation).  Compare against X-Internal-Token header.
# RATE_LIMIT_BYPASS_TOKENS=token-a,token-b

# ── CORS Configuration (Issue #408) ──────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all origins
# (development only). In production, set explicit origins.
# Example: CORS_ALLOWED_ORIGINS=https://app.inheritx.com,https://admin.inheritx.com
CORS_ALLOWED_ORIGINS=

# ── Request Timeout (Issue #409) ─────────────────────────────────────────────
# Maximum seconds a request handler may run before returning 408.
REQUEST_TIMEOUT_SECS=30

# ── Secrets Management (Issue #410) ──────────────────────────────────────────
# Backend to use for secrets: "env" (default, reads from this file / environment)
# or "aws" (reads from AWS Secrets Manager).
SECRETS_BACKEND=env

# Required when SECRETS_BACKEND=aws
# AWS_REGION=us-east-1
# AWS credentials are resolved via the standard AWS credential chain
# (IAM role, AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, ~/.aws/credentials, etc.)
# Do NOT hardcode credentials here.

# ── Database Connection Pool (Issue #420) ─────────────────────────────────────
# All variables are optional. Defaults shown are tuned for production.
# Adjust based on your PostgreSQL max_connections setting and expected load.

# Maximum number of connections the pool will open simultaneously.
# Keep this below postgresql.conf max_connections (default 100).
# Rule of thumb: (num_cpu_cores * 2) + effective_spindle_count
# Default: 10
DB_POOL_MAX_CONNECTIONS=10

# Minimum number of idle connections kept open at all times.
# Keeps the pool "warm" so requests after quiet periods don't pay
# connection-setup latency. Default: 2
DB_POOL_MIN_CONNECTIONS=2

# Seconds to wait for a connection from the pool before returning a 503.
# Default: 30
DB_POOL_ACQUIRE_TIMEOUT_SECS=30

# Seconds an idle connection may sit in the pool before being closed.
# Prevents stale connections after a DB restart or network partition.
# Default: 600 (10 minutes)
DB_POOL_IDLE_TIMEOUT_SECS=600

# Maximum lifetime of any connection regardless of activity.
# Forces periodic reconnection so server-side resource limits are respected.
# Default: 1800 (30 minutes)
DB_POOL_MAX_LIFETIME_SECS=1800

# Number of times to retry the initial pool creation on startup failure.
# Handles transient races (e.g. DB container not yet ready in docker-compose).
# Default: 5
DB_POOL_CONNECT_RETRIES=5

# Base delay in seconds between retry attempts (doubles each attempt, max 60 s).
# Default: 2
DB_POOL_CONNECT_RETRY_BASE_DELAY_SECS=2

# ── Prometheus Metrics (Issue #423) ───────────────────────────────────────────
# The /metrics endpoint is enabled by default and requires no configuration.
# Restrict access at the network / ingress layer in production (e.g. only
# expose it on an internal port or behind an IP allowlist).

# How often (in seconds) the background task refreshes the DB pool gauges.
# Lower values give fresher data but add minor CPU overhead.
# Default: 15
METRICS_POOL_SCRAPE_INTERVAL_SECS=15

# ── Error Tracking / Sentry (Issue #424) ──────────────────────────────────────
# Leave SENTRY_DSN empty to disable error tracking (safe for local development).
# In production/staging, set this to your project's DSN from sentry.io.
# Example: SENTRY_DSN=https://abc123@o0.ingest.sentry.io/0000000
SENTRY_DSN=

# Fraction of error events to send to Sentry (0.0–1.0).
# Default: 1.0 (capture all errors). Reduce only under extreme volume.
SENTRY_SAMPLE_RATE=1.0

# Fraction of transactions to send for performance tracing (0.0–1.0).
# Default: 0.1 (10%). Set to 1.0 in staging for full visibility.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Whether to include the user's IP address in error reports.
# Set to "false" if your privacy policy prohibits it.
# Default: true
SENTRY_SEND_DEFAULT_PII=true
